pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command: ['sleep']
    args: ['99d']
  - name: helm
    image: alpine/helm:3.12.0
    command: ['sleep']
    args: ['99d']
"""
        }
    }
    stages {
        stage('Build Image') {
            steps {
                container('kaniko') {
                    echo "Construim imaginea cu Kaniko..."
                    sh '/kaniko/executor --context . --dockerfile Dockerfile --destination python-test-app:latest --no-push'
                }
            }
        }
        stage('Helm Deploy') {
            steps {
                container('helm') {
                    echo "Lansăm aplicația în K3s..."
                    sh 'helm upgrade --install python-test-app ./charts/python-app-chart --namespace default'
                }
            }
        }
    }
    post {
        success {
            echo 'Aplicația a fost construită și instalată cu succes!'
        }
        failure {
            echo 'Ceva nu a mers bine. Verifică logurile de Kaniko sau Helm.'
        }
    }
}
